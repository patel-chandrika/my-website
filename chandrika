<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Chandrika Patel – Business Analyst Portfolio</title>
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;600;700;900&family=Rajdhani:wght@300;400;500;600;700&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&display=swap" rel="stylesheet"/>
<style>
/* ===================== RESET & BASE ===================== */
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;font-size:16px;}
body{
  background:#020010;
  color:#e2e8f0;
  font-family:'Rajdhani',sans-serif;
  overflow-x:hidden;
  cursor:none;
}

/* ===================== VARIABLES ===================== */
:root{
  --neon-blue:#00d4ff;
  --neon-purple:#a855f7;
  --neon-pink:#f472b6;
  --bg-deep:#020010;
  --bg-card:rgba(255,255,255,0.035);
  --border:rgba(0,212,255,0.15);
  --border-purple:rgba(168,85,247,0.2);
  --text:#e2e8f0;
  --muted:rgba(226,232,240,0.55);
  --glow-b:0 0 25px rgba(0,212,255,0.35),0 0 70px rgba(0,212,255,0.12);
  --glow-p:0 0 25px rgba(168,85,247,0.35),0 0 70px rgba(168,85,247,0.12);
  --glow-pk:0 0 20px rgba(244,114,182,0.35);
}

/* ===================== CURSOR ===================== */
.cursor{
  position:fixed;width:10px;height:10px;
  background:var(--neon-blue);border-radius:50%;
  pointer-events:none;z-index:9999;
  transform:translate(-50%,-50%);
  box-shadow:var(--glow-b);
  transition:transform .08s;
}
.cursor-ring{
  position:fixed;width:30px;height:30px;
  border:1px solid rgba(0,212,255,.35);border-radius:50%;
  pointer-events:none;z-index:9998;
  transform:translate(-50%,-50%);
  transition:all .15s ease;
}

/* ===================== BG EFFECTS ===================== */
.bg-grid{
  position:fixed;inset:0;z-index:0;
  background-image:
    linear-gradient(rgba(0,212,255,.04) 1px,transparent 1px),
    linear-gradient(90deg,rgba(0,212,255,.04) 1px,transparent 1px);
  background-size:64px 64px;
  animation:gridDrift 25s linear infinite;
}
@keyframes gridDrift{from{background-position:0 0}to{background-position:64px 64px}}

.orb{position:fixed;border-radius:50%;filter:blur(90px);pointer-events:none;z-index:0;}
.orb-1{width:500px;height:500px;background:rgba(168,85,247,.1);top:-150px;left:-150px;animation:floatOrb 12s ease-in-out infinite;}
.orb-2{width:400px;height:400px;background:rgba(0,212,255,.08);bottom:5%;right:-100px;animation:floatOrb 14s ease-in-out infinite -5s;}
.orb-3{width:300px;height:300px;background:rgba(244,114,182,.07);top:45%;left:45%;animation:floatOrb 10s ease-in-out infinite -8s;}
@keyframes floatOrb{0%,100%{transform:translateY(0) scale(1)}50%{transform:translateY(-40px) scale(1.08)}}

/* ===================== NAV ===================== */
nav{
  position:fixed;top:0;left:0;right:0;z-index:1000;
  padding:18px 70px;
  display:flex;align-items:center;justify-content:space-between;
  background:rgba(2,0,16,.7);
  backdrop-filter:blur(24px);
  border-bottom:1px solid var(--border);
}
.nav-logo{
  font-family:'Orbitron',monospace;font-size:1.25rem;font-weight:900;
  background:linear-gradient(135deg,var(--neon-blue),var(--neon-purple));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;
  letter-spacing:3px;text-decoration:none;
}
.nav-links{display:flex;gap:32px;list-style:none;}
.nav-links a{
  color:var(--muted);text-decoration:none;
  font-size:.82rem;letter-spacing:2.5px;text-transform:uppercase;font-weight:600;
  position:relative;transition:color .3s;
}
.nav-links a::after{
  content:'';position:absolute;bottom:-5px;left:0;width:0;height:1px;
  background:linear-gradient(90deg,var(--neon-blue),var(--neon-purple));
  transition:width .3s;
}
.nav-links a:hover{color:var(--neon-blue);}
.nav-links a:hover::after{width:100%;}
.nav-menu-btn{display:none;background:none;border:1px solid var(--border);
  color:var(--neon-blue);padding:8px 14px;border-radius:6px;cursor:none;
  font-family:'Orbitron';font-size:.7rem;letter-spacing:2px;}

/* ===================== LAYOUT ===================== */
section{position:relative;z-index:1;}
.container{max-width:1200px;margin:0 auto;padding:0 60px;}

/* ===================== ANIMATIONS ===================== */
@keyframes fadeUp{from{opacity:0;transform:translateY(32px)}to{opacity:1;transform:translateY(0)}}
@keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.5;transform:scale(1.5)}}
@keyframes spin{from{transform:rotate(0)}to{transform:rotate(360deg)}}
@keyframes shimmer{0%{background-position:-200% center}100%{background-position:200% center}}
@keyframes blink{0%,100%{opacity:1}50%{opacity:0}}

.fade-up{opacity:0;transform:translateY(32px);transition:opacity .7s,transform .7s;}
.fade-up.visible{opacity:1;transform:translateY(0);}

/* ===================== SHARED COMPONENTS ===================== */
.section-tag{
  display:inline-block;padding:4px 18px;border-radius:50px;
  background:rgba(168,85,247,.1);border:1px solid rgba(168,85,247,.3);
  font-size:.72rem;letter-spacing:3px;text-transform:uppercase;
  color:var(--neon-purple);margin-bottom:14px;
}
.section-title{
  font-family:'Orbitron',monospace;font-size:clamp(1.9rem,3.5vw,3rem);font-weight:900;
  color:#fff;line-height:1.15;
}
.section-title span{
  background:linear-gradient(135deg,var(--neon-blue),var(--neon-purple));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;
}
.section-line{
  width:60px;height:2px;margin-top:18px;
  background:linear-gradient(90deg,var(--neon-blue),var(--neon-purple));
  border-radius:2px;box-shadow:var(--glow-b);
}
.section-divider{
  height:1px;max-width:1200px;margin:0 auto;
  background:linear-gradient(90deg,transparent,var(--neon-blue),var(--neon-purple),transparent);
  opacity:.25;
}

.glass-card{
  background:var(--bg-card);
  border:1px solid var(--border);
  backdrop-filter:blur(20px);
  border-radius:18px;
  position:relative;overflow:hidden;
}
.glass-card::before{
  content:'';position:absolute;top:0;left:0;right:0;height:2px;
  background:linear-gradient(90deg,var(--neon-blue),var(--neon-purple),var(--neon-pink));
}

.btn-primary{
  display:inline-flex;align-items:center;gap:8px;
  padding:14px 32px;border-radius:8px;border:none;cursor:none;
  background:linear-gradient(135deg,var(--neon-blue),var(--neon-purple));
  color:#fff;font-family:'Rajdhani';font-size:.95rem;font-weight:700;
  letter-spacing:2px;text-transform:uppercase;
  position:relative;overflow:hidden;
  box-shadow:0 0 30px rgba(0,212,255,.3);
  transition:all .3s;text-decoration:none;
}
.btn-primary::before{
  content:'';position:absolute;inset:0;
  background:linear-gradient(135deg,var(--neon-purple),var(--neon-pink));
  opacity:0;transition:opacity .3s;
}
.btn-primary:hover{transform:translateY(-3px);box-shadow:0 0 50px rgba(0,212,255,.5);}
.btn-primary:hover::before{opacity:1;}
.btn-primary span{position:relative;z-index:1;}

.btn-outline{
  display:inline-flex;align-items:center;gap:8px;
  padding:14px 32px;border-radius:8px;cursor:none;
  border:1px solid rgba(0,212,255,.4);
  background:transparent;color:var(--neon-blue);
  font-family:'Rajdhani';font-size:.95rem;font-weight:700;
  letter-spacing:2px;text-transform:uppercase;
  transition:all .3s;text-decoration:none;
}
.btn-outline:hover{
  background:rgba(0,212,255,.08);border-color:var(--neon-blue);
  box-shadow:var(--glow-b);transform:translateY(-3px);
}

/* ===================== HOME ===================== */
#home{
  min-height:100vh;
  display:flex;align-items:center;justify-content:center;
  padding:120px 60px 80px;
}
.home-inner{
  display:grid;grid-template-columns:1fr 1fr;gap:60px;
  align-items:center;max-width:1200px;width:100%;
}

.home-badge{
  display:inline-flex;align-items:center;gap:8px;
  padding:7px 20px;border-radius:50px;
  background:var(--bg-card);border:1px solid rgba(0,212,255,.25);
  font-size:.75rem;letter-spacing:3px;text-transform:uppercase;
  color:var(--neon-blue);margin-bottom:24px;
  animation:fadeUp .8s .2s both;
}
.badge-dot{width:7px;height:7px;border-radius:50%;background:var(--neon-blue);box-shadow:var(--glow-b);animation:pulse 1.5s infinite;}

.home-greeting{font-size:1.1rem;color:var(--muted);letter-spacing:3px;text-transform:uppercase;font-weight:500;animation:fadeUp .8s .3s both;}
.home-name{font-family:'Orbitron',monospace;font-size:clamp(2.4rem,5vw,4rem);font-weight:900;line-height:1.05;margin:6px 0;animation:fadeUp .8s .4s both;}
.name-first{color:#fff;}
.name-last{
  background:linear-gradient(135deg,var(--neon-blue) 0%,var(--neon-purple) 55%,var(--neon-pink) 100%);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;
  background-size:200% auto;animation:shimmer 4s linear infinite;
  display:block;
}
.home-role{
  font-size:1.15rem;color:var(--neon-purple);font-weight:600;
  letter-spacing:3px;margin-bottom:20px;animation:fadeUp .8s .5s both;
}
.typing-cursor{animation:blink 1s infinite;color:var(--neon-blue);}
.home-desc{
  font-size:1rem;color:var(--muted);line-height:1.9;
  max-width:480px;margin-bottom:36px;font-family:'DM Sans',sans-serif;font-weight:300;
  animation:fadeUp .8s .6s both;
}
.home-ctas{display:flex;gap:16px;margin-bottom:44px;animation:fadeUp .8s .7s both;}

.home-stats{display:flex;gap:40px;animation:fadeUp .8s .9s both;}
.hs-item{}
.hs-num{
  font-family:'Orbitron',monospace;font-size:2rem;font-weight:900;
  background:linear-gradient(135deg,var(--neon-blue),var(--neon-purple));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;
}
.hs-label{font-size:.75rem;color:var(--muted);letter-spacing:2px;text-transform:uppercase;margin-top:3px;}

/* Profile Card */
.home-visual{display:flex;align-items:center;justify-content:center;position:relative;animation:fadeUp .8s .5s both;}
.profile-card{position:relative;width:360px;height:420px;}
.card-glow-border{
  position:absolute;inset:-2px;border-radius:22px;
  background:linear-gradient(135deg,var(--neon-blue),var(--neon-purple),var(--neon-pink),var(--neon-blue));
  background-size:300% 300%;
  animation:shimmer 3s linear infinite;
  padding:2px;border-radius:22px;
}
.card-inner{
  width:100%;height:100%;border-radius:20px;
  background:linear-gradient(135deg,rgba(10,0,40,.97),rgba(4,0,26,.97));
  backdrop-filter:blur(20px);
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  padding:36px;gap:14px;
}
.profile-avatar{
  width:120px;height:120px;border-radius:50%;
  background:linear-gradient(135deg,var(--neon-purple),var(--neon-blue));
  display:flex;align-items:center;justify-content:center;
  font-family:'Orbitron',monospace;font-size:2.4rem;font-weight:900;color:#fff;
  box-shadow:0 0 40px rgba(168,85,247,.5),0 0 80px rgba(0,212,255,.2);
  position:relative;
}
.avatar-ring{
  position:absolute;inset:-10px;border-radius:50%;
  border:1px solid rgba(0,212,255,.3);animation:spin 8s linear infinite;
}
.avatar-ring::before{
  content:'';position:absolute;top:-4px;left:50%;transform:translateX(-50%);
  width:8px;height:8px;border-radius:50%;background:var(--neon-blue);box-shadow:var(--glow-b);
}
.avatar-ring-2{
  position:absolute;inset:-20px;border-radius:50%;
  border:1px solid rgba(168,85,247,.15);animation:spin 14s linear infinite reverse;
}
.card-name{font-family:'Orbitron',monospace;font-size:1.05rem;font-weight:700;color:#fff;text-align:center;}
.card-role{font-size:.8rem;color:var(--neon-blue);letter-spacing:2px;text-transform:uppercase;font-weight:600;}
.card-divider{width:60%;height:1px;background:linear-gradient(90deg,transparent,rgba(0,212,255,.3),transparent);}
.card-stats{display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;width:100%;}
.cs-item{
  background:rgba(0,212,255,.05);border:1px solid rgba(0,212,255,.1);
  border-radius:10px;padding:10px 6px;text-align:center;
}
.cs-num{
  font-family:'Orbitron',monospace;font-size:1rem;font-weight:700;
  background:linear-gradient(135deg,var(--neon-blue),var(--neon-purple));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;
}
.cs-label{font-size:.6rem;color:var(--muted);letter-spacing:1px;text-transform:uppercase;margin-top:3px;}

.float-tags{position:absolute;}
.float-tags.left{left:-115px;top:80px;}
.float-tags.right{right:-115px;top:80px;}
.ftag{
  background:rgba(4,0,26,.9);border:1px solid var(--border);
  backdrop-filter:blur(10px);border-radius:50px;
  padding:7px 16px;font-size:.73rem;color:var(--neon-blue);
  letter-spacing:1px;white-space:nowrap;margin-bottom:10px;
  animation:floatOrb 6s ease-in-out infinite;
}
.ftag:nth-child(2){animation-delay:-2s;}
.ftag:nth-child(3){animation-delay:-4s;}

.scroll-hint{
  position:absolute;bottom:36px;left:50%;transform:translateX(-50%);
  display:flex;flex-direction:column;align-items:center;gap:8px;
  opacity:.45;animation:fadeUp 1s 1.3s both;
}
.scroll-hint span{font-size:.68rem;letter-spacing:3px;text-transform:uppercase;color:var(--muted);}
.scroll-line{width:1px;height:0;background:linear-gradient(180deg,var(--neon-blue),transparent);animation:scrollGrow 2s ease-in-out infinite;}
@keyframes scrollGrow{0%{height:0;opacity:1}100%{height:50px;opacity:0}}

/* ===================== ABOUT ===================== */
#about{min-height:100vh;padding:120px 60px;display:flex;align-items:center;justify-content:center;}
.about-inner{
  max-width:1200px;width:100%;
  display:grid;grid-template-columns:1fr 1.3fr;gap:80px;align-items:start;
}
.about-card{padding:36px;}
.about-av-row{display:flex;align-items:center;gap:18px;margin-bottom:28px;}
.about-av{
  width:80px;height:80px;border-radius:50%;flex-shrink:0;
  background:linear-gradient(135deg,var(--neon-blue),var(--neon-purple));
  display:flex;align-items:center;justify-content:center;
  font-family:'Orbitron',monospace;font-size:1.5rem;font-weight:900;color:#fff;
  box-shadow:0 0 30px rgba(0,212,255,.4);
}
.about-av-name{font-family:'Orbitron',monospace;font-size:1rem;font-weight:700;color:#fff;}
.about-av-role{font-size:.8rem;color:var(--neon-blue);letter-spacing:2px;text-transform:uppercase;margin-top:4px;}
.info-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
.info-item{
  background:rgba(0,212,255,.04);border:1px solid rgba(0,212,255,.09);
  border-radius:10px;padding:12px 14px;
}
.info-key{font-size:.65rem;color:var(--muted);letter-spacing:2px;text-transform:uppercase;margin-bottom:5px;}
.info-val{font-size:.87rem;color:var(--text);font-weight:600;}
.info-val a{color:var(--neon-blue);text-decoration:none;transition:text-shadow .3s;}
.info-val a:hover{text-shadow:var(--glow-b);}
.avail-badge{
  display:inline-flex;align-items:center;gap:8px;margin-top:22px;
  padding:8px 20px;border-radius:50px;
  background:rgba(74,222,128,.06);border:1px solid rgba(74,222,128,.2);
  font-size:.78rem;color:#4ade80;letter-spacing:2px;text-transform:uppercase;
}
.avail-dot{width:7px;height:7px;border-radius:50%;background:#4ade80;box-shadow:0 0 10px #4ade80;animation:pulse 1.5s infinite;}

.mini-cards{margin-top:18px;display:flex;flex-direction:column;gap:12px;}
.mini-card{
  background:var(--bg-card);border:1px solid var(--border);
  backdrop-filter:blur(12px);border-radius:12px;padding:14px 18px;
  display:flex;align-items:center;gap:14px;
  animation:floatOrb 7s ease-in-out infinite;
}
.mini-card:nth-child(2){animation-delay:-3.5s;}
.mini-icon{
  width:40px;height:40px;border-radius:10px;flex-shrink:0;
  background:linear-gradient(135deg,var(--neon-purple),var(--neon-pink));
  display:flex;align-items:center;justify-content:center;font-size:1.1rem;
  box-shadow:var(--glow-p);
}
.mini-text strong{display:block;color:#fff;font-size:.88rem;margin-bottom:2px;}
.mini-text span{font-size:.77rem;color:var(--muted);}

.about-desc{font-size:.98rem;color:var(--muted);line-height:1.9;font-family:'DM Sans',sans-serif;font-weight:300;margin-bottom:24px;}
.about-desc em{color:var(--neon-blue);font-style:normal;font-weight:500;}
.quote-box{
  background:var(--bg-card);border:1px solid var(--border);border-left:3px solid var(--neon-purple);
  border-radius:0 14px 14px 0;padding:22px 26px;margin-bottom:28px;font-style:italic;
  font-family:'DM Sans',sans-serif;font-size:.98rem;color:var(--muted);line-height:1.8;
}

.skill-bars{margin-bottom:28px;}
.sbar{margin-bottom:16px;}
.sbar-head{display:flex;justify-content:space-between;margin-bottom:8px;}
.sbar-name{font-size:.88rem;color:var(--text);font-weight:600;letter-spacing:1px;}
.sbar-pct{font-size:.78rem;color:var(--neon-blue);font-family:'Orbitron',monospace;}
.sbar-track{height:4px;border-radius:4px;background:rgba(255,255,255,.06);}
.sbar-fill{
  height:100%;border-radius:4px;
  background:linear-gradient(90deg,var(--neon-blue),var(--neon-purple));
  box-shadow:0 0 12px rgba(0,212,255,.4);
  transform:scaleX(0);transform-origin:left;
  transition:transform 1.3s cubic-bezier(.16,1,.3,1);
}
.sbar-fill.on{transform:scaleX(1);}

.tag-cloud{display:flex;flex-wrap:wrap;gap:10px;}
.atag{
  padding:6px 16px;border-radius:50px;
  background:rgba(168,85,247,.07);border:1px solid rgba(168,85,247,.2);
  font-size:.78rem;color:var(--neon-purple);letter-spacing:1px;
  transition:all .3s;
}
.atag:hover{background:rgba(168,85,247,.18);box-shadow:var(--glow-p);color:#fff;}

/* ===================== SKILLS ===================== */
#skills{padding:120px 60px;}
.skills-header{text-align:center;margin-bottom:64px;}
.skills-grid{
  max-width:1200px;margin:0 auto;
  display:grid;grid-template-columns:repeat(3,1fr);gap:24px;
}
.skill-cat{
  background:var(--bg-card);border:1px solid var(--border);
  backdrop-filter:blur(16px);border-radius:16px;
  padding:28px;position:relative;overflow:hidden;
  transition:border-color .3s,transform .3s;
}
.skill-cat::before{
  content:'';position:absolute;top:0;left:0;right:0;height:2px;
  background:linear-gradient(90deg,var(--neon-blue),var(--neon-purple));
}
.skill-cat:hover{border-color:rgba(0,212,255,.35);transform:translateY(-4px);}
.sc-icon{font-size:1.8rem;margin-bottom:14px;}
.sc-title{
  font-family:'Orbitron',monospace;font-size:.9rem;font-weight:700;
  color:var(--neon-blue);letter-spacing:2px;margin-bottom:16px;
}
.sc-list{list-style:none;display:flex;flex-direction:column;gap:8px;}
.sc-list li{
  font-size:.85rem;color:var(--muted);
  display:flex;align-items:center;gap:8px;
}
.sc-list li::before{
  content:'▹';color:var(--neon-purple);font-size:.8rem;flex-shrink:0;
}

/* Tools pills */
.tools-row{
  max-width:1200px;margin:40px auto 0;
  display:flex;flex-wrap:wrap;gap:14px;justify-content:center;
}
.tool-pill{
  display:flex;align-items:center;gap:10px;
  padding:10px 22px;border-radius:50px;
  background:var(--bg-card);border:1px solid var(--border);
  backdrop-filter:blur(12px);font-size:.82rem;color:var(--text);font-weight:600;
  letter-spacing:1px;transition:all .3s;
}
.tool-pill:hover{border-color:var(--neon-blue);box-shadow:var(--glow-b);color:var(--neon-blue);}
.tool-icon{font-size:1.1rem;}

/* ===================== PROJECTS ===================== */
#projects{padding:120px 60px;}
.projects-header{text-align:center;margin-bottom:64px;}
.projects-grid{max-width:1200px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:32px;}
.project-card{
  background:var(--bg-card);border:1px solid var(--border);
  backdrop-filter:blur(20px);border-radius:20px;
  padding:36px;position:relative;overflow:hidden;
  transition:border-color .3s,transform .3s;
}
.project-card::before{
  content:'';position:absolute;top:0;left:0;right:0;height:2px;
  background:linear-gradient(90deg,var(--neon-blue),var(--neon-purple),var(--neon-pink));
}
.project-card:hover{border-color:rgba(0,212,255,.35);transform:translateY(-6px);}
.pc-num{
  font-family:'Orbitron',monospace;font-size:3.5rem;font-weight:900;
  color:rgba(0,212,255,.08);position:absolute;top:16px;right:24px;line-height:1;
}
.pc-badge{
