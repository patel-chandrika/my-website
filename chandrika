<!-- ===================== JS ===================== -->
<script>
/* Cursor */
const cur = document.getElementById('cur');
const curR = document.getElementById('curR');
let mx=0,my=0,rx=0,ry=0;
document.addEventListener('mousemove',e=>{
  mx=e.clientX;my=e.clientY;
  cur.style.left=mx+'px';cur.style.top=my+'px';
});
(function trail(){
  rx+=(mx-rx)*.15;ry+=(my-ry)*.15;
  curR.style.left=rx+'px';curR.style.top=ry+'px';
  requestAnimationFrame(trail);
})();
document.querySelectorAll('a,button,.skill-cat,.project-card,.edu-card,.cert-card,.tool-pill,.atag,.contact-link').forEach(el=>{
  el.addEventListener('mouseenter',()=>{cur.style.transform='translate(-50%,-50%) scale(2)';curR.style.transform='translate(-50%,-50%) scale(1.5)';});
  el.addEventListener('mouseleave',()=>{cur.style.transform='translate(-50%,-50%) scale(1)';curR.style.transform='translate(-50%,-50%) scale(1)';});
});

/* Scroll animations */
const io = new IntersectionObserver(entries=>{
  entries.forEach(e=>{
    if(e.isIntersecting){
      e.target.classList.add('visible');
      // trigger skill bars if inside
      e.target.querySelectorAll('.sbar-fill').forEach(b=>b.classList.add('on'));
    }
  });
},{threshold:.15});
document.querySelectorAll('.fade-up').forEach(el=>io.observe(el));

/* Skill bar widths from inline style */
document.querySelectorAll('.sbar-fill').forEach(b=>{
  const w = b.style.getPropertyValue('--w') || '0';
  b.style.width=(parseFloat(w)*100)+'%';
});

/* Typing animation */
const roles = ['Business Analyst','Data Analyst','Process Analyst','BA Aspirant'];
let ri=0,ci=0,deleting=false;
const el=document.querySelector('.home-role');
function typeIt(){
  const word=roles[ri];
  if(!deleting){
    ci++;if(ci>word.length){deleting=true;setTimeout(typeIt,1500);return;}
  } else {
    ci--;if(ci===0){deleting=false;ri=(ri+1)%roles.length;}
  }
  el.innerHTML=word.slice(0,ci)+'<span class="typing-cursor">|</span>';
  setTimeout(typeIt,deleting?60:110);
}
typeIt();

/* Mobile menu */
function toggleMenu(){
  const nl=document.getElementById('navLinks');
  nl.style.display=nl.style.display==='flex'?'none':'flex';
  nl.style.flexDirection='column';
  nl.style.position='fixed';
  nl.style.top='70px';nl.style.right='24px';
  nl.style.background='rgba(2,0,16,.97)';
  nl.style.border='1px solid rgba(0,212,255,.2)';
  nl.style.borderRadius='12px';nl.style.padding='24px 32px';
  nl.style.gap='20px';nl.style.zIndex='999';
}

/* Contact form */
function sendMessage(){
  const name=document.getElementById('fname').value.trim();
  const email=document.getElementById('femail').value.trim();
  const subject=document.getElementById('fsubject').value.trim();
  const msg=document.getElementById('fmessage').value.trim();
  if(!name||!email||!msg){alert('Please fill in all required fields.');return;}
  const mailto=`mailto:patelchandrika5062@gmail.com?subject=${encodeURIComponent(subject||'Portfolio Contact')}&body=${encodeURIComponent('Name: '+name+'\nEmail: '+email+'\n\n'+msg)}`;
  window.location.href=mailto;
}

/* Smooth scroll for nav links */
document.querySelectorAll('a[href^="#"]').forEach(a=>{
  a.addEventListener('click',e=>{
    e.preventDefault();
    const t=document.querySelector(a.getAttribute('href'));
    if(t)t.scrollIntoView({behavior:'smooth'});
    const nl=document.getElementById('navLinks');
    if(window.innerWidth<=860)nl.style.display='none';
  });
});
</script>
